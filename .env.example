# Copy to .env.local and fill in real values. Never commit .env.local.
# ONE Next.js app now serves both the admin (/admin) and the public site.
# CI's own Supabase project — see CLAUDE.md golden rules. NEVER point this at
# the Astro-Psyche Lab / Gabriela project.

# Supabase — shared by admin (SSR/cookie client) and public (anon build client)
NEXT_PUBLIC_SUPABASE_URL=https://lfyerbxqfwjjftcpjzbv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical base for metadata / sitemap / robots / JSON-LD. Falls back to the
# vercel.app URL if unset (see lib/seo.ts), but set it explicitly in production.
NEXT_PUBLIC_SITE_URL=https://conciencia-inquieta.vercel.app

# MailerLite (CI's own account/audience) — server-only, used by /api/suscribir.
# UNPREFIXED so it's never exposed to the client. Enable double opt-in on the group.
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=

# Secondary broadcast channel — channel-agnostic until decided (WhatsApp | Telegram).
# The CTA renders nothing until both are set. One of: whatsapp | telegram
NEXT_PUBLIC_SECONDARY_CHANNEL_TYPE=
NEXT_PUBLIC_SECONDARY_CHANNEL_URL=

# Analytics + Meta Pixel (all optional; site works without them).
NEXT_PUBLIC_ANALYTICS_PROVIDER=plausible
NEXT_PUBLIC_ANALYTICS_DOMAIN=
NEXT_PUBLIC_META_PIXEL_ID=
