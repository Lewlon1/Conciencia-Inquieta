# Copy to .env and fill in real values. Never commit .env.
# Same CI Supabase project as the admin's .env.local — anon (public) key only,
# this is a static site built with the publishable key, never the service role key.

PUBLIC_SUPABASE_URL=https://lfyerbxqfwjjftcpjzbv.supabase.co
PUBLIC_SUPABASE_ANON_KEY=

# Used for canonical URLs / sitemap / structured data. Set to the real
# vercel.app URL once deployed (Session 5), then the custom domain later.
PUBLIC_SITE_URL=https://conciencia-inquieta.vercel.app

# Session 4 — MailerLite (CI's own account, never co-mingled with another
# client's list). Server-side only, used by the /api/suscribir endpoint.
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=

# Session 4 — secondary broadcast channel, channel-agnostic until decided
# (see MVP Build plan "Open decisions"). One of: whatsapp | telegram
PUBLIC_SECONDARY_CHANNEL_TYPE=
PUBLIC_SECONDARY_CHANNEL_URL=

# Session 5 — analytics + Meta Pixel (both optional; site works without them)
PUBLIC_ANALYTICS_PROVIDER=plausible
PUBLIC_ANALYTICS_DOMAIN=
PUBLIC_META_PIXEL_ID=
