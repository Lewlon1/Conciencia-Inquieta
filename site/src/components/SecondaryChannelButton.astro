---
// Channel-agnostic secondary CTA — WhatsApp Channel vs Telegram is an open
// decision (see MVP Build plan "Open decisions"). Renders nothing until
// PUBLIC_SECONDARY_CHANNEL_TYPE/URL are set, so it's safe to place on every
// page ahead of that decision.
interface Props {
  dark?: boolean;
}
const { dark = false } = Astro.props;

const type = import.meta.env.PUBLIC_SECONDARY_CHANNEL_TYPE;
const url = import.meta.env.PUBLIC_SECONDARY_CHANNEL_URL;

const labels: Record<string, string> = {
  whatsapp: "Síguenos en WhatsApp →",
  telegram: "Síguenos en Telegram →",
};
const label = type ? labels[type] : null;
---

{url && label && (
  <a
    class={`btn-line ${dark ? "on-dark" : ""}`}
    href={url}
    target="_blank"
    rel="noopener noreferrer"
    data-event="channel_click"
    data-channel={type}
  >
    {label}
  </a>
)}
