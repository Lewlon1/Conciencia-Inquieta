---
// Free MailerLite email-list signup — CI's own audience, double opt-in.
// POST /api/suscribir always redirects back to /unete?ok=1|0&source=... —
// this page is static (prerender=true), so success/error state can't be
// read server-side from the query string. Both states are rendered here and
// toggled client-side by the script below, which also fires the `signup`
// analytics event. Runs harmlessly (no-op) on every other page, since only
// /unete ever receives an `ok` param.
interface Props {
  source: string;
  dark?: boolean;
}
const { source, dark = false } = Astro.props;
---

<div class="subscribe-block">
  <form class="subscribe-form" action="/api/suscribir" method="post">
    <div class="row">
      <input type="email" name="email" placeholder="tucorreo@ejemplo.com" aria-label="Email" required />
      <button class="btn-amber" type="submit">Únete →</button>
    </div>
    <input type="hidden" name="source" value={source} />
    <p class="note error" data-subscribe-error hidden>No hemos podido procesar tu suscripción. Inténtalo de nuevo.</p>
    <p class="legal" style={dark ? "" : "color:var(--muted)"}>
      Un email a la semana, como mucho. Cancela cuando quieras. Nunca compartimos tu dirección.
    </p>
  </form>
  <div class="success" data-subscribe-success hidden>
    <div class="tick">✓</div>
    <h3>Revisa tu correo</h3>
    <p>Te hemos enviado un email para confirmar tu suscripción (doble opt-in). Sin confirmar, no recibirás nada.</p>
  </div>
</div>

<script>
  const params = new URLSearchParams(location.search);
  const ok = params.get("ok");
  if (ok === "1" || ok === "0") {
    document.querySelectorAll(".subscribe-block").forEach((block) => {
      const form = block.querySelector(".subscribe-form");
      const success = block.querySelector("[data-subscribe-success]");
      const error = block.querySelector("[data-subscribe-error]");
      if (ok === "1") {
        form?.setAttribute("hidden", "");
        success?.removeAttribute("hidden");
      } else {
        error?.removeAttribute("hidden");
      }
    });
    if (ok === "1") {
      window.ciTrack?.("signup", { source: params.get("source") || "unknown" });
    }
  }
</script>
