---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="wrap">
    <div class="foot-top">
      <div>
        <div class="wm2">Conciencia <i>Inquieta</i></div>
        <p class="bio">Diario digital autogestionado. No practicamos la neutralidad, sino la verdad con contexto, memoria y humanidad.</p>
      </div>
      <div class="fcol">
        <h5>Secciones</h5>
        <a href="/articulos">Artículos</a>
        <a href="/sobre-nosotras">Sobre nosotras</a>
        <a href="/contacto">Contacto</a>
        <a href="/unete">Únete</a>
      </div>
      <div class="fcol">
        <h5>Legal</h5>
        <a href="/privacidad">Aviso legal &amp; privacidad</a>
        <a href="/cookies">Cookies</a>
        <a href="/terminos">Términos</a>
      </div>
      <div class="fcol">
        <h5>Boletín</h5>
        <p class="bio" style="margin-top:0">Las conversaciones que faltan, en tu correo.</p>
        <form class="fnews" action="/api/suscribir" method="post">
          <input type="email" name="email" placeholder="Tu email" aria-label="Email para el boletín" required />
          <input type="hidden" name="source" value="footer" />
          <button type="submit">Unirme</button>
        </form>
      </div>
    </div>
    <div class="foot-bottom">
      <span>© {year} Conciencia Inquieta · Hecho con conciencia</span>
      <div class="fsoc">
        <a href="#">Instagram</a>
        <a href="#">X</a>
        <a href="#">TikTok</a>
        <a href="#">YouTube</a>
      </div>
    </div>
  </div>
</footer>
