---
import { formatDate } from "../lib/content";
import type { ArticleWithRelations } from "../lib/types";
import { gradFor, glyphFor } from "../lib/categoryStyle";

interface Props {
  article: ArticleWithRelations;
  variant?: "card" | "mini" | "lead";
}
const { article, variant = "card" } = Astro.props;
const href = `/articulos/${article.slug}`;
const catName = article.category?.name ?? "";
const authorName = article.author?.name ?? "Redacción";
---

{variant === "lead" && (
  <a class="lead" href={href}>
    <div class="ph" data-cat={catName} style={`background:${gradFor(catName)}`}>
      {article.featured_image_url ? (
        <img src={article.featured_image_url} alt="" />
      ) : (
        <span class="glyph">{glyphFor(catName)}</span>
      )}
    </div>
    <div class="cat">{catName}</div>
    <h3>{article.title}</h3>
    {article.subtitle && <p>{article.subtitle}</p>}
    <div class="meta" style="margin-top:14px;font-size:.8rem;color:var(--muted)">
      {authorName} · {formatDate(article.published_at)} · {article.reading_time_min} min de lectura
    </div>
  </a>
)}

{variant === "mini" && (
  <a class="mini" href={href}>
    <div class="ph" data-cat={catName} style={`background:${gradFor(catName)}`}>
      {article.featured_image_url ? (
        <img src={article.featured_image_url} alt="" />
      ) : (
        <span class="glyph">{glyphFor(catName)}</span>
      )}
    </div>
    <div>
      <div class="cat" style="margin-bottom:7px">{catName}</div>
      <h4>{article.title}</h4>
      <div class="meta">{authorName} · {article.reading_time_min} min</div>
    </div>
  </a>
)}

{variant === "card" && (
  <a class="card" href={href}>
    <div class="ph" data-cat={catName} style={`background:${gradFor(catName)}`}>
      {article.featured_image_url ? (
        <img src={article.featured_image_url} alt="" />
      ) : (
        <span class="glyph">{glyphFor(catName)}</span>
      )}
    </div>
    <div class="body">
      <div><span class="cat">{catName}</span></div>
      <h3>{article.title}</h3>
      {article.subtitle && <p>{article.subtitle}</p>}
      <div class="meta">
        <span>{authorName}</span>·<span>{article.reading_time_min} min</span>
      </div>
    </div>
  </a>
)}
