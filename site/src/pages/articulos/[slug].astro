---
export const prerender = true;

import { marked } from "marked";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { getPublishedArticles, getRelatedArticles, formatDate } from "../../lib/content";
import { gradFor, glyphFor } from "../../lib/categoryStyle";
import SubscribeForm from "../../components/SubscribeForm.astro";

export async function getStaticPaths() {
  const articles = await getPublishedArticles();
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article, related: getRelatedArticles(article, articles) },
  }));
}

const { article, related } = Astro.props;

const catName = article.category?.name ?? "";
const authorName = article.author?.name ?? "Redacción";
const authorInitials = authorName
  .split(" ")
  .map((w: string) => w[0])
  .slice(0, 2)
  .join("")
  .toUpperCase();

const bodyHtml = article.content ? await marked.parse(article.content) : "";

const canonical = new URL(`/articulos/${article.slug}`, Astro.site).toString();
const shareText = encodeURIComponent(article.title);
const shareUrl = encodeURIComponent(canonical);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  headline: article.title,
  description: article.subtitle || article.meta_description || undefined,
  image: article.featured_image_url || undefined,
  datePublished: article.published_at || undefined,
  dateModified: article.updated_at || article.published_at || undefined,
  author: { "@type": "Person", name: authorName },
  publisher: {
    "@type": "Organization",
    name: "Conciencia Inquieta",
    logo: { "@type": "ImageObject", url: new URL("/favicon.svg", Astro.site).toString() },
  },
  mainEntityOfPage: canonical,
  keywords: article.tags.join(", ") || undefined,
};
---

<BaseLayout
  title={article.meta_title || `${article.title} — Conciencia Inquieta`}
  description={article.meta_description || article.subtitle || ""}
  active="articulos"
  jsonLd={[articleSchema]}
>
  <div class="wrap">
    <article class="article">
      <div class="eyebrow">
        {catName && <span class="cat">{catName}</span>}
        <span style="font-size:.8rem;color:var(--muted)">
          {formatDate(article.published_at)} · {article.reading_time_min} min de lectura
        </span>
      </div>
      <h1>{article.title}</h1>
      {article.subtitle && <p class="deck">{article.subtitle}</p>}

      <div class="byline">
        <div class="byavatar">{authorInitials}</div>
        <div class="bm">
          <b>{authorName}</b><br /><span>Redacción · Conciencia Inquieta</span>
        </div>
        <div class="share">
          <a href={`https://twitter.com/intent/tweet?text=${shareText}&url=${shareUrl}`} target="_blank" rel="noopener noreferrer" title="Compartir en X">✕</a>
          <a href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`} target="_blank" rel="noopener noreferrer" title="Compartir en Facebook">f</a>
          <a href={`https://wa.me/?text=${shareText}%20${shareUrl}`} target="_blank" rel="noopener noreferrer" title="Compartir en WhatsApp">✆</a>
          <a href={`mailto:?subject=${shareText}&body=${shareUrl}`} title="Compartir por email">✉</a>
        </div>
      </div>

      <div class="ph hero-img" data-cat={catName} style={`background:${gradFor(catName)}`}>
        {article.featured_image_url ? (
          <img src={article.featured_image_url} alt={article.featured_image_alt || ""} />
        ) : (
          <span class="glyph">{glyphFor(catName)}</span>
        )}
      </div>

      <div class="prose" set:html={bodyHtml} />

      {article.tags.length > 0 && (
        <div class="tags">
          {article.tags.map((tag: string) => <span class="tag">{tag}</span>)}
        </div>
      )}
    </article>
  </div>

  <div class="wrap">
    <div class="article" style="max-width:var(--maxread)">
      <div class="subscribe" style="padding:34px">
        <div>
          <h2 style="font-size:1.5rem">¿Te ha hecho pensar?</h2>
          <p>Recibe lo nuevo directamente en tu correo, sin depender de ningún algoritmo.</p>
        </div>
        <SubscribeForm source="end-of-article" dark />
      </div>
    </div>
  </div>

  {related.length > 0 && (
    <div class="wrap">
      <div class="related">
        <div class="shead"><h2>Seguir leyendo<span class="dot">.</span></h2></div>
        <div class="grid">
          {related.map((a: typeof article) => <ArticleCard article={a} />)}
        </div>
      </div>
    </div>
  )}
</BaseLayout>

<script is:inline define:vars={{ slug: article.slug }}>
  // "article_read" fires once, ~5s after load (a crude but honest proxy for
  // "opened and stayed" rather than a bounce). "scroll_depth" fires once at
  // 75% of document height. Both from MVP Build plan Session 5's event list.
  let readFired = false;
  let scrollFired = false;

  setTimeout(function () {
    if (readFired) return;
    readFired = true;
    window.ciTrack?.("article_read", { slug: slug });
  }, 5000);

  window.addEventListener(
    "scroll",
    function () {
      if (scrollFired) return;
      const doc = document.documentElement;
      const scrolled = (doc.scrollTop + doc.clientHeight) / doc.scrollHeight;
      if (scrolled >= 0.75) {
        scrollFired = true;
        window.ciTrack?.("scroll_depth", { slug: slug, depth: "75" });
      }
    },
    { passive: true }
  );
</script>
