---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import SubscribeForm from "../components/SubscribeForm.astro";
import SecondaryChannelButton from "../components/SecondaryChannelButton.astro";
import { getPublishedArticles, getCategories } from "../lib/content";

const articles = await getPublishedArticles();
const categories = await getCategories();

const lead = articles[0];
const sideMinis = articles.slice(1, 4);
const latest = articles.slice(0, 6);

const tickerPrompts = [
  "¿Quién cuida a quienes cuidan?",
  "¿De qué no se habla en las noticias?",
  "¿Qué memoria estamos dejando morir?",
  "¿A quién incomoda la verdad?",
  "¿Cómo se sana en colectivo?",
  "¿Qué voces faltan en esta conversación?",
];
const tickerSet = [...tickerPrompts, ...tickerPrompts];
---

<BaseLayout
  title="Conciencia Inquieta — diario digital autogestionado"
  description="Noticias que importan, conversaciones que faltan, reflexiones que sanan. Diario digital independiente: derechos humanos, feminismo, Latinoamérica, cultura y más."
  active="home"
>
  <div class="wrap">
    <div class="masthead">
      <div class="kicker">Diario digital autogestionado</div>
      <h1 class="wordmark">Conciencia <i>Inquieta</i></h1>
      <p class="tagline">Noticias que importan, conversaciones que faltan, reflexiones que sanan.</p>
    </div>
  </div>

  <div class="ticker" aria-hidden="true">
    <div class="ticker-row">
      {tickerSet.map((t) => <span>{t}</span>)}
    </div>
  </div>

  {lead && (
    <div class="wrap">
      <div class="front">
        <ArticleCard article={lead} variant="lead" />
        <div class="front-side">
          {sideMinis.map((a) => <ArticleCard article={a} variant="mini" />)}
        </div>
      </div>
    </div>
  )}

  <div class="wrap section">
    <div class="shead"><h2>Lo último<span class="dot">.</span></h2><a class="seeall" href="/articulos">Ver todos los artículos →</a></div>
    {latest.length > 0 ? (
      <div class="grid">
        {latest.map((a) => <ArticleCard article={a} />)}
      </div>
    ) : (
      <p style="color:var(--muted);font-family:var(--read);font-style:italic">Todavía no hay artículos publicados.</p>
    )}
  </div>

  <div class="wrap section">
    <div class="shead"><h2>Explora por tema<span class="dot">.</span></h2></div>
    <div class="chips">
      {categories.map((c) => (
        <a class="chip" href={`/categoria/${c.slug}`}>{c.name}</a>
      ))}
    </div>
  </div>

  <div class="wrap section">
    <div class="subscribe">
      <div>
        <h2>Un periodismo que no se calla necesita a su comunidad</h2>
        <p>Sin grandes anunciantes ni dueños. Suscríbete para recibir lo nuevo directamente en tu correo, sin algoritmos de por medio.</p>
        <div style="margin-top:20px"><SecondaryChannelButton dark /></div>
      </div>
      <SubscribeForm source="home" dark />
    </div>
  </div>
</BaseLayout>
